<Window x:Class="CyberShieldGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="CyberShield - Cybersecurity Awareness Bot"
        Height="760" Width="1020"
        MinHeight="600" MinWidth="820"
        WindowStartupLocation="CenterScreen"
        Background="White"
        Loaded="Window_Loaded">

    <Window.Resources>

        <!-- Style for sidebar topic buttons -->
        <Style x:Key="SidebarButton" TargetType="Button">
            <Setter Property="Background"                 Value="White"/>
            <Setter Property="Foreground"                 Value="#374151"/>
            <Setter Property="BorderBrush"                Value="#E5E7EB"/>
            <Setter Property="BorderThickness"            Value="1"/>
            <Setter Property="Padding"                    Value="10,8"/>
            <Setter Property="Margin"                     Value="0,3"/>
            <Setter Property="FontFamily"                 Value="Segoe UI"/>
            <Setter Property="FontSize"                   Value="12"/>
            <Setter Property="Cursor"                     Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background"   Value="#EEF2FF"/>
                                <Setter Property="BorderBrush"  Value="#6366F1"/>
                                <Setter Property="Foreground"   Value="#4F46E5"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background"   Value="#E0E7FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style for the primary action buttons (Start Session, Send) -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background"      Value="#4F46E5"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="20,10"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#4338CA"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#3730A3"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#C7D2FE"/>
                                <Setter Property="Foreground" Value="#818CF8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style for text input fields -->
        <Style x:Key="ChatInput" TargetType="TextBox">
            <Setter Property="Background"      Value="White"/>
            <Setter Property="Foreground"      Value="#111827"/>
            <Setter Property="BorderBrush"     Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="12,10"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="CaretBrush"      Value="#4F46E5"/>
            <Setter Property="SelectionBrush"  Value="#C7D2FE"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Padding="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#4F46E5"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#F9FAFB"/>
                                <Setter Property="Foreground" Value="#9CA3AF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header bar -->
            <RowDefinition Height="Auto"/>
            <!-- Name entry panel -->
            <RowDefinition Height="*"/>
            <!-- Chat area and sidebar -->
            <RowDefinition Height="Auto"/>
            <!-- Message input bar -->
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0"
                Background="#4F46E5"
                Padding="20,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Bot avatar circle -->
                <Border Grid.Column="0"
                        Width="44" Height="44"
                        CornerRadius="22"
                        Background="#6366F1"
                        BorderBrush="White"
                        BorderThickness="2"
                        VerticalAlignment="Center"
                        Margin="0,0,14,0">
                    <TextBlock Text="CS"
                               FontSize="14" FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <!-- Bot name and status -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="CyberShield"
                               FontSize="18" FontWeight="Bold"
                               Foreground="White" FontFamily="Segoe UI"/>
                    <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                        <Ellipse Width="8" Height="8" Fill="#4ADE80"
                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock x:Name="StatusLabel"
                                   Text="Online Now"
                                   FontSize="12" Foreground="#C7D2FE"
                                   FontFamily="Segoe UI"/>
                    </StackPanel>
                </StackPanel>

                <!-- Session user display -->
                <TextBlock x:Name="UserNameLabel"
                           Grid.Column="2"
                           Text=""
                           FontSize="13" Foreground="#C7D2FE"
                           FontFamily="Segoe UI"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- NAME ENTRY PANEL — hidden after session starts -->
        <Border x:Name="NameEntryPanel"
                Grid.Row="1"
                Background="#F5F3FF"
                BorderBrush="#E0E7FF"
                BorderThickness="0,0,0,1"
                Padding="20,14"
                Visibility="Visible">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Welcome! Please enter your name to begin."
                               FontSize="13" Foreground="#4B5563"
                               FontFamily="Segoe UI"/>
                </StackPanel>

                <TextBox x:Name="NameInputBox"
                         Grid.Column="1"
                         Style="{StaticResource ChatInput}"
                         Margin="14,0"
                         VerticalContentAlignment="Center"
                         KeyDown="NameInputBox_KeyDown"/>

                <Button Grid.Column="2"
                        Content="Start Session"
                        Style="{StaticResource PrimaryButton}"
                        Click="StartSessionButton_Click"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- CHAT AREA AND SIDEBAR -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="210"/>
            </Grid.ColumnDefinitions>

            <!-- Scrollable chat message area -->
            <ScrollViewer x:Name="ChatScrollViewer"
                          Grid.Column="0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Background="#F9FAFB"
                          Padding="20,16,20,10">
                <StackPanel x:Name="MessagesPanel"/>
            </ScrollViewer>

            <!-- Right sidebar with topic buttons -->
            <Border Grid.Column="1"
                    Background="White"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="12,16,12,12">

                        <TextBlock Text="QUICK TOPICS"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="#6B7280" FontFamily="Segoe UI"
                                   Margin="2,0,0,10"/>

                        <Button Content="Password Safety"
                                Style="{StaticResource SidebarButton}"
                                Tag="Tell me about password safety"
                                Click="QuickTopic_Click"/>
                        <Button Content="Phishing Scams"
                                Style="{StaticResource SidebarButton}"
                                Tag="Tell me about phishing"
                                Click="QuickTopic_Click"/>
                        <Button Content="Online Privacy"
                                Style="{StaticResource SidebarButton}"
                                Tag="Tell me about privacy"
                                Click="QuickTopic_Click"/>
                        <Button Content="Malware"
                                Style="{StaticResource SidebarButton}"
                                Tag="Tell me about malware"
                                Click="QuickTopic_Click"/>
                        <Button Content="Ransomware"
                                Style="{StaticResource SidebarButton}"
                                Tag="Tell me about ransomware"
                                Click="QuickTopic_Click"/>
                        <Button Content="Two-Factor Authentication"
                                Style="{StaticResource SidebarButton}"
                                Tag="Tell me about 2FA"
                                Click="QuickTopic_Click"/>
                        <Button Content="Wi-Fi Safety"
                                Style="{StaticResource SidebarButton}"
                                Tag="Tell me about wifi safety"
                                Click="QuickTopic_Click"/>
                        <Button Content="VPN"
                                Style="{StaticResource SidebarButton}"
                                Tag="Tell me about VPN"
                                Click="QuickTopic_Click"/>
                        <Button Content="Online Scams"
                                Style="{StaticResource SidebarButton}"
                                Tag="Tell me about online scams"
                                Click="QuickTopic_Click"/>

                        <Rectangle Fill="#E5E7EB" Height="1" Margin="2,14,2,10"/>

                        <TextBlock Text="COMMANDS"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="#6B7280" FontFamily="Segoe UI"
                                   Margin="2,0,0,10"/>

                        <Button Content="Tell me more"
                                Style="{StaticResource SidebarButton}"
                                Tag="Tell me more"
                                Click="QuickTopic_Click"/>
                        <Button Content="Another tip"
                                Style="{StaticResource SidebarButton}"
                                Tag="Give me another tip"
                                Click="QuickTopic_Click"/>
                        <Button Content="What can you do?"
                                Style="{StaticResource SidebarButton}"
                                Tag="What can you do?"
                                Click="QuickTopic_Click"/>

                        <Rectangle Fill="#E5E7EB" Height="1" Margin="2,14,2,10"/>

                        <TextBlock Text="SESSION"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="#6B7280" FontFamily="Segoe UI"
                                   Margin="2,0,0,8"/>

                        <!-- Shows the topic the user has stored as their interest -->
                        <TextBlock x:Name="InterestLabel"
                                   Text="No interest stored yet."
                                   FontSize="11" Foreground="#9CA3AF"
                                   FontFamily="Segoe UI"
                                   TextWrapping="Wrap"
                                   Margin="2,0"/>

                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- MESSAGE INPUT BAR -->
        <Border Grid.Row="3"
                Background="White"
                BorderBrush="#E5E7EB"
                BorderThickness="0,1,0,0"
                Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="MessageInputBox"
                         Grid.Column="0"
                         Style="{StaticResource ChatInput}"
                         Margin="0,0,10,0"
                         IsEnabled="False"
                         VerticalContentAlignment="Center"
                         KeyDown="MessageInputBox_KeyDown"/>

                <Button x:Name="SendBtn"
                        Grid.Column="1"
                        Content="Send"
                        Style="{StaticResource PrimaryButton}"
                        IsEnabled="False"
                        Click="SendButton_Click"/>
            </Grid>
        </Border>

    </Grid>
</Window>
