<Window x:Class="CyberShieldGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="CyberShield - Cybersecurity Awareness Bot"
        Height="780" Width="1060"
        MinHeight="620" MinWidth="820"
        WindowStartupLocation="CenterScreen"
        Background="#F0F4F8"
        Loaded="Window_Loaded">

    <Window.Resources>

        <!-- Quick-reply pill button (matches the outlined pills in the image) -->
        <Style x:Key="QuickReplyButton" TargetType="Button">
            <Setter Property="Background"      Value="White"/>
            <Setter Property="Foreground"      Value="#1D4ED8"/>
            <Setter Property="BorderBrush"     Value="#1D4ED8"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding"         Value="14,7"/>
            <Setter Property="Margin"          Value="4,3"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="20"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background"  Value="#EFF6FF"/>
                                <Setter Property="BorderBrush" Value="#1E40AF"/>
                                <Setter Property="Foreground"  Value="#1E40AF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#DBEAFE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Solid pill button (blue filled, like "Shipping" in the image) -->
        <Style x:Key="SolidPillButton" TargetType="Button" BasedOn="{StaticResource QuickReplyButton}">
            <Setter Property="Background" Value="#1D4ED8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#1D4ED8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="20"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1E40AF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Round blue send button -->
        <Style x:Key="SendButton" TargetType="Button">
            <Setter Property="Background"      Value="#1D4ED8"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width"           Value="48"/>
            <Setter Property="Height"          Value="48"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="24">
                            <TextBlock Text="➤"
                                       FontSize="18" Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Margin="2,0,0,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1E40AF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1E3A8A"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#93C5FD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Message text input -->
        <Style x:Key="MessageInput" TargetType="TextBox">
            <Setter Property="Background"      Value="White"/>
            <Setter Property="Foreground"      Value="#111827"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="4,12"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="CaretBrush"      Value="#1D4ED8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderThickness="0">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Padding="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Name entry input -->
        <Style x:Key="NameInput" TargetType="TextBox">
            <Setter Property="Background"      Value="White"/>
            <Setter Property="Foreground"      Value="#111827"/>
            <Setter Property="BorderBrush"     Value="#BFDBFE"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="12,10"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="CaretBrush"      Value="#1D4ED8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Padding="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#1D4ED8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Start session button -->
        <Style x:Key="StartButton" TargetType="Button">
            <Setter Property="Background"      Value="#1D4ED8"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="20,10"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1E40AF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Blue gradient header  -->
            <RowDefinition Height="Auto"/>
            <!-- Name entry (hidden after start) -->
            <RowDefinition Height="*"/>
            <!-- Chat messages         -->
            <RowDefinition Height="Auto"/>
            <!-- Quick-reply pills     -->
            <RowDefinition Height="Auto"/>
            <!-- Input bar             -->
        </Grid.RowDefinitions>

        <!-- ══ HEADER — blue gradient with profile circle, name, online status ══ -->
        <Border Grid.Row="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#1D4ED8" Offset="0"/>
                    <GradientStop Color="#3B82F6" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid Margin="20,18,20,22">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Profile circle (matches the image avatar style) -->
                <Border Grid.Column="0"
                        Width="52" Height="52"
                        CornerRadius="26"
                        BorderBrush="White"
                        BorderThickness="2.5"
                        VerticalAlignment="Center"
                        Margin="0,0,14,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#60A5FA" Offset="0"/>
                            <GradientStop Color="#2563EB" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock Text="CS"
                               FontSize="16" FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <!-- Name and online status -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Chat with"
                               FontSize="11" Foreground="#BFDBFE"
                               FontFamily="Segoe UI" Margin="0,0,0,1"/>
                    <TextBlock Text="CyberShield"
                               FontSize="20" FontWeight="Bold"
                               Foreground="White" FontFamily="Segoe UI"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <Ellipse Width="8" Height="8" Fill="#4ADE80"
                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock x:Name="StatusLabel"
                                   Text="We're online"
                                   FontSize="12" Foreground="#BFDBFE"
                                   FontFamily="Segoe UI"/>
                    </StackPanel>
                </StackPanel>

                <!-- User name shown after session starts -->
                <TextBlock x:Name="UserNameLabel"
                           Grid.Column="2"
                           Text=""
                           FontSize="12" Foreground="#BFDBFE"
                           FontFamily="Segoe UI"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"/>
            </Grid>

            <!-- Wave shape at the bottom of the header (like the image) -->
            <Border.Effect>
                <DropShadowEffect Color="#1D4ED8" BlurRadius="12" Opacity="0.4" ShadowDepth="4"/>
            </Border.Effect>
        </Border>

        <!-- ══ NAME ENTRY PANEL ══ -->
        <Border x:Name="NameEntryPanel"
                Grid.Row="1"
                Background="#EFF6FF"
                BorderBrush="#BFDBFE"
                BorderThickness="0,0,0,1"
                Padding="20,14"
                Visibility="Visible">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="240"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Welcome! Please enter your name to begin chatting."
                           FontSize="13" Foreground="#1E40AF"
                           FontFamily="Segoe UI" VerticalAlignment="Center"/>

                <TextBox x:Name="NameInputBox"
                         Grid.Column="1"
                         Style="{StaticResource NameInput}"
                         Margin="14,0"
                         VerticalContentAlignment="Center"
                         KeyDown="NameInputBox_KeyDown"/>

                <Button Grid.Column="2"
                        Content="Start Chat"
                        Style="{StaticResource StartButton}"
                        Click="StartSessionButton_Click"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ══ CHAT MESSAGES AREA ══ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="200"/>
            </Grid.ColumnDefinitions>

            <!-- Scrollable message history -->
            <ScrollViewer x:Name="ChatScrollViewer"
                          Grid.Column="0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Background="#F8FAFC"
                          Padding="20,16,20,10">
                <StackPanel x:Name="MessagesPanel"/>
            </ScrollViewer>

            <!-- Right sidebar — topic shortcuts -->
            <Border Grid.Column="1"
                    Background="White"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="10,14,10,14">

                        <TextBlock Text="QUICK TOPICS"
                                   FontSize="9" FontWeight="Bold"
                                   Foreground="#6B7280" FontFamily="Segoe UI"
                                   Margin="2,0,0,8"/>

                        <Button Content=" Password Safety"    Style="{StaticResource QuickReplyButton}" Tag="Tell me about password safety" Click="QuickTopic_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"/>
                        <Button Content=" Phishing Scams"     Style="{StaticResource QuickReplyButton}" Tag="Tell me about phishing"        Click="QuickTopic_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"/>
                        <Button Content=" Online Privacy"    Style="{StaticResource QuickReplyButton}" Tag="Tell me about privacy"         Click="QuickTopic_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"/>
                        <Button Content=" Malware"            Style="{StaticResource QuickReplyButton}" Tag="Tell me about malware"         Click="QuickTopic_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"/>
                        <Button Content=" Ransomware"         Style="{StaticResource QuickReplyButton}" Tag="Tell me about ransomware"      Click="QuickTopic_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"/>
                        <Button Content=" 2FA"                Style="{StaticResource QuickReplyButton}" Tag="Tell me about 2FA"             Click="QuickTopic_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"/>
                        <Button Content=" Wi-Fi Safety"       Style="{StaticResource QuickReplyButton}" Tag="Tell me about wifi safety"     Click="QuickTopic_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"/>
                        <Button Content=" VPN"                Style="{StaticResource QuickReplyButton}" Tag="Tell me about VPN"             Click="QuickTopic_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"/>
                        <Button Content=" Online Scams"       Style="{StaticResource QuickReplyButton}" Tag="Tell me about online scams"    Click="QuickTopic_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"/>

                        <Rectangle Fill="#E5E7EB" Height="1" Margin="2,10,2,10"/>

                        <TextBlock Text="PART 3"
                                   FontSize="9" FontWeight="Bold"
                                   Foreground="#6B7280" FontFamily="Segoe UI"
                                   Margin="2,0,0,8"/>

                        <Button Content=" My Tasks"        Style="{StaticResource SolidPillButton}" Tag="show tasks"          Click="QuickTopic_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"/>
                        <Button Content=" Add Task"         Style="{StaticResource QuickReplyButton}" Tag="add task: Enable two-factor authentication" Click="QuickTopic_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"/>
                        <Button Content=" Start Quiz"      Style="{StaticResource SolidPillButton}" Tag="start quiz"         Click="QuickTopic_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"/>
                        <Button Content=" Activity Log"    Style="{StaticResource QuickReplyButton}" Tag="show activity log"  Click="QuickTopic_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"/>

                        <Rectangle Fill="#E5E7EB" Height="1" Margin="2,10,2,10"/>

                        <TextBlock Text="SESSION"
                                   FontSize="9" FontWeight="Bold"
                                   Foreground="#6B7280" FontFamily="Segoe UI"
                                   Margin="2,0,0,6"/>

                        <TextBlock x:Name="InterestLabel"
                                   Text="No interest stored yet."
                                   FontSize="11" Foreground="#9CA3AF"
                                   FontFamily="Segoe UI"
                                   TextWrapping="Wrap" Margin="2,0"/>

                        <TextBlock x:Name="LogCountLabel"
                                   Text="Log entries: 0"
                                   FontSize="11" Foreground="#9CA3AF"
                                   FontFamily="Segoe UI" Margin="2,4,2,0"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ══ QUICK-REPLY PILLS (shown above input, like in the image) ══ -->
        <Border Grid.Row="3"
                Background="White"
                BorderBrush="#F1F5F9"
                BorderThickness="0,1,0,0"
                Padding="16,8,16,4">
            <WrapPanel Orientation="Horizontal">
                <Button Content="Tell me more"     Style="{StaticResource QuickReplyButton}" Tag="Tell me more"        Click="QuickTopic_Click"/>
                <Button Content="Another tip"      Style="{StaticResource QuickReplyButton}" Tag="Give me another tip" Click="QuickTopic_Click"/>
                <Button Content="What can you do?" Style="{StaticResource QuickReplyButton}" Tag="What can you do?"    Click="QuickTopic_Click"/>
                <Button Content="Show my tasks"    Style="{StaticResource SolidPillButton}"  Tag="show tasks"          Click="QuickTopic_Click"/>
                <Button Content="Start quiz"       Style="{StaticResource SolidPillButton}"  Tag="start quiz"          Click="QuickTopic_Click"/>
            </WrapPanel>
        </Border>

        <!-- ══ INPUT BAR — white card with text box and round send button ══ -->
        <Border Grid.Row="4"
                Background="White"
                BorderBrush="#E2E8F0"
                BorderThickness="0,1,0,0"
                Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Input field inside a rounded card -->
                <Border Grid.Column="0"
                        Background="White"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1"
                        CornerRadius="24"
                        Padding="16,4"
                        Margin="0,0,10,0">
                    <TextBox x:Name="MessageInputBox"
                             Style="{StaticResource MessageInput}"
                             IsEnabled="False"
                             VerticalContentAlignment="Center"
                             KeyDown="MessageInputBox_KeyDown"/>
                </Border>

                <!-- Round send button -->
                <Button x:Name="SendBtn"
                        Grid.Column="1"
                        Style="{StaticResource SendButton}"
                        IsEnabled="False"
                        Click="SendButton_Click"/>
            </Grid>
        </Border>

    </Grid>
</Window>
